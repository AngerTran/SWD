@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="login-section">
    <div class="login-box text-center animate__animated animate__zoomIn">

        <div class="login-icon">
            <i class="bi bi-lock-fill"></i>
        </div>

        <h2 class="fw-bold mb-1">Chào mừng quay lại</h2>
        <p class="text-muted mb-4 small">Đăng nhập để vào dashboard theo vai trò của bạn</p>

        @if (TempData["LogoutMessage"] is string logoutMsg && !string.IsNullOrEmpty(logoutMsg))
        {
            <div class="alert alert-success small mb-3" role="alert">@logoutMsg</div>
        }
        @if (ViewData["Error"] is string err && !string.IsNullOrEmpty(err))
        {
            <div class="alert alert-danger small mb-3" role="alert">@err</div>
        }

        <form method="post" action="/login" class="text-start">
            @Html.AntiForgeryToken()

            <div class="form-input-group">
                <label class="form-label">Email công việc</label>
                <input type="email" name="email" class="form-control" placeholder="username@fpt.edu.vn" required />
            </div>

            <div class="form-input-group">
                <label class="form-label">Mật khẩu</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required />
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 px-1">
                <div class="form-check small">
                    <input class="form-check-input bg-dark border-secondary" type="checkbox" id="rememberMe" name="rememberMe" value="true">
                    <label class="form-check-label text-muted" for="rememberMe">Ghi nhớ tôi</label>
                </div>
                <a href="#" class="small text-primary text-decoration-none">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn btn-primary-glow w-100 py-3 mb-4">
                Đăng nhập hệ thống
            </button>
        </form>

        <p class="small text-muted mb-0">
            Tài khoản mẫu: admin@fpt.edu.vn / lecturer@fpt.edu.vn / leader@fpt.edu.vn / member@fpt.edu.vn (mk: Admin@123, Lecturer@123, Leader@123, Member@123)
        </p>
        <p class="small text-muted mb-0">
            Gặp sự cố? <a href="#" class="text-white text-decoration-none fw-600">Liên hệ hỗ trợ</a>
        </p>
    </div>
</section>
