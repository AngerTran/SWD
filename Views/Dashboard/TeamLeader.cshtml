@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Team Leader";
}

<div class="page-header animate__animated animate__fadeIn">
    <div class="page-header-flex">
        <div>
            <h1 class="page-title">Quản lý nhóm</h1>
            <p class="text-muted">Đồng bộ Jira và quản lý tiến độ thành viên.</p>
        </div>
        <div class="flex gap-3">
            <a href="/Dashboard/Sync" class="btn btn-cancel" style="display: inline-flex; align-items: center;"><i class="fas fa-sync" style="margin-right: 0.5rem;"></i> Đồng bộ Jira</a>
            <a href="/Dashboard/SRS" class="btn-add"><i class="fas fa-file-signature"></i> Tạo SRS</a>
        </div>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon stat-icon-blue"><i class="fas fa-tasks"></i></div>
        <div id="statTotal" class="stat-value">0/0</div>
        <div class="stat-label">Tasks (Done/Total)</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon stat-icon-purple"><i class="fas fa-code-branch"></i></div>
        <div id="statCommits" class="stat-value">0</div>
        <div class="stat-label">Commits nhóm</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon stat-icon-green"><i class="fas fa-chart-pie"></i></div>
        <div id="statProgress" class="stat-value">0%</div>
        <div class="stat-label">Tiến độ</div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="content-card animate__animated animate__fadeInUp">
        <div class="card-header">
            <h2 class="card-title">Tasks gần đây</h2>
            <a href="/Dashboard/Tasks" class="link-primary">Quản lý tasks</a>
        </div>
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Tiêu đề</th>
                        <th>Người thực hiện</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody id="tasksBody">
                    <tr><td colspan="3" class="text-center" style="padding: 2rem;">Đang tải...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="content-card animate__animated animate__fadeInUp">
        <div class="card-header">
            <h2 class="card-title">Đóng góp thành viên</h2>
            <a href="/Dashboard/Commits" class="link-primary">Xem Commits</a>
        </div>
        <div id="contributionsBody" style="font-size: 0.875rem; color: var(--text-muted);">
            Đang tải...
        </div>
    </div>
</div>

<script>
(function() {
    var currentGroupId = null;
    var opts = { credentials: 'include' };

    function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

    async function loadDashboardData() {
        var groupsRes = await fetch('/api/groups', opts);
        var groups = await groupsRes.json();
        if (groups.length === 0) {
            document.getElementById('tasksBody').innerHTML = '<tr><td colspan="3" class="text-center" style="padding: 2rem; color: var(--text-muted);">Chưa có nhóm.</td></tr>';
            return;
        }
        currentGroupId = groups[0].id;

        var statsRes = await fetch('/api/reports/progress?groupId=' + currentGroupId, opts);
        var stats = await statsRes.json();
        document.getElementById('statTotal').textContent = (stats.done || 0) + '/' + (stats.total || 0);
        document.getElementById('statProgress').textContent = (stats.total > 0 ? Math.round((stats.done / stats.total) * 100) : 0) + '%';

        var tasksRes = await fetch('/api/tasks?groupId=' + currentGroupId, opts);
        var tasks = await tasksRes.json();
        var tasksBody = document.getElementById('tasksBody');
        var list = tasks.slice(0, 8);
        if (list.length === 0) tasksBody.innerHTML = '<tr><td colspan="3" class="text-center" style="padding: 2rem;">Chưa có task.</td></tr>';
        else tasksBody.innerHTML = list.map(function(t) {
            var assignee = t.assigneeUserName || (t.assigneeUserId ? t.assigneeUserId.toString().substring(0, 8) + '...' : '—');
            var statusClass = t.status === 2 ? 'status-done' : (t.status === 1 ? 'status-progress' : 'status-todo');
            var statusText = t.status === 2 ? 'Done' : (t.status === 1 ? 'In Progress' : 'Todo');
            return '<tr><td>' + esc(t.title) + '</td><td>' + esc(assignee) + '</td><td><span class="status-badge ' + statusClass + '">' + statusText + '</span></td></tr>';
        }).join('');

        var totalCommits = 0;
        try {
            var cRes = await fetch('/api/reports/commit-stats?groupId=' + currentGroupId, opts);
            if (cRes.ok) { var d = await cRes.json(); if (d.byUser) totalCommits = d.byUser.reduce(function(s, x) { return s + (x.count || 0); }, 0); }
        } catch (e) {}
        document.getElementById('statCommits').textContent = totalCommits;
        document.getElementById('contributionsBody').innerHTML = '<p>Tổng commits nhóm: <strong>' + totalCommits + '</strong>. Xem chi tiết tại <a href="/Dashboard/Commits" class="link-primary">Commits</a>.</p>';
    }

    if (document.readyState === 'loading') window.addEventListener('DOMContentLoaded', loadDashboardData); else loadDashboardData();
})();
</script>
