@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Commits & GitHub";
    var isLecturer = ViewBag.IsLecturer as bool? ?? false;
    var isTeamLeader = ViewBag.IsTeamLeader as bool? ?? false;
    var isTeamMember = ViewBag.IsTeamMember as bool? ?? false;
    var isAdmin = ViewBag.IsAdmin as bool? ?? false;
}

<div class="page-header animate__animated animate__fadeIn">
    <h1 class="page-title">Commits & GitHub</h1>
    <p class="text-muted">Thống kê commit và đóng góp cá nhân — xem ai làm và làm được gì.</p>
    @if (isLecturer || isAdmin)
    {
        <div class="form-input-group" style="max-width: 280px; margin-top: 0.75rem;">
            <label class="form-label">Chọn nhóm</label>
            <select id="groupFilter" class="form-control">
                <option value="">-- Chọn nhóm --</option>
            </select>
        </div>
    }
</div>

<!-- Thẻ đóng góp theo thành viên -->
<section class="content-card animate__animated animate__fadeInUp" style="margin-bottom: 1.5rem;">
    <h2 class="card-title" style="margin-bottom: 1rem;">Đóng góp theo thành viên</h2>
    <div id="memberCards" class="member-cards">
        <p class="text-muted">Đang tải...</p>
    </div>
</section>

<!-- Biểu đồ commit theo tuần -->
<section class="content-card animate__animated animate__fadeInUp" style="margin-bottom: 1.5rem;">
    <h2 class="card-title" style="margin-bottom: 1rem;">Commit theo tuần — theo thành viên</h2>
    <div id="chartContainer" class="commit-chart-container">
        <p class="text-muted">Chọn nhóm hoặc xem dữ liệu của bạn.</p>
    </div>
</section>

<!-- Lịch sử commit -->
<section class="content-card animate__animated animate__fadeInUp">
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 1rem;">
        <h2 class="card-title" style="margin: 0;">Commit History</h2>
        <div style="position: relative; max-width: 280px;">
            <input type="text" id="searchCommit" class="form-control" placeholder="Tìm commit..." style="padding-left: 2.25rem;">
            <i class="fas fa-search" style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 0.875rem;"></i>
        </div>
    </div>
    <div id="commitHistoryList" class="commit-history-list">
        <p class="text-muted">Đang tải...</p>
    </div>
</section>

<style>
.member-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
.member-card {
    background: rgba(255,255,255,0.04); border: 1px solid var(--glass-border); border-radius: 16px;
    padding: 1.25rem; text-align: center;
}
.member-card .avatar { width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #3b82f6, #8b5cf6); color: #fff; font-weight: 700; font-size: 1.25rem; display: flex; align-items: center; justify-content: center; margin: 0 auto 0.5rem; }
.member-card .name { font-weight: 600; margin-bottom: 0.25rem; }
.member-card .commits { font-size: 1.5rem; font-weight: 700; color: #60a5fa; }
.commit-chart-container { min-height: 200px; }
.chart-bars { display: flex; align-items: flex-end; gap: 4px; padding: 1rem 0; }
.chart-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; }
.chart-bar { width: 100%; max-width: 32px; background: linear-gradient(180deg, #3b82f6, #60a5fa); border-radius: 6px 6px 0 0; min-height: 4px; }
.commit-history-list { max-height: 420px; overflow-y: auto; }
.commit-item {
    display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.75rem 0; border-bottom: 1px solid var(--border-color);
}
.commit-item .commit-icon { width: 28px; height: 28px; border-radius: 8px; background: rgba(59,130,246,0.2); color: #60a5fa; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; flex-shrink: 0; }
.commit-item .commit-icon.fix { background: rgba(239,68,68,0.2); color: #f87171; }
.commit-item .commit-icon.chore { background: rgba(148,163,184,0.2); color: #94a3b8; }
.commit-item .body { flex: 1; min-width: 0; }
.commit-item .message { font-weight: 500; margin-bottom: 0.25rem; }
.commit-item .meta { font-size: 0.8125rem; color: var(--text-muted); }
.commit-item .sha { font-family: monospace; font-size: 0.75rem; color: var(--text-muted); }
</style>

<script>
(function() {
    const isLecturer = @(isLecturer ? "true" : "false");
    const isTeamLeader = @(isTeamLeader ? "true" : "false");
    const isTeamMember = @(isTeamMember ? "true" : "false");
    const isAdmin = @(isAdmin ? "true" : "false");

    let currentGroupId = null;
    let currentUserId = null;
    let allCommits = [];

    const opts = { credentials: 'include' };

    async function loadGroups() {
        const res = await fetch('/api/groups', opts);
        const groups = await res.json();
        const sel = document.getElementById('groupFilter');
        if (sel) {
            sel.innerHTML = '<option value="">-- Chọn nhóm --</option>' + groups.map(g => `<option value="${g.id}">${escapeHtml(g.code)} - ${escapeHtml(g.name)}</option>`).join('');
            sel.onchange = () => { currentGroupId = sel.value || null; loadAll(); };
        }
        if (groups.length && isTeamLeader) {
            currentGroupId = groups[0].id;
            if (sel) { sel.value = currentGroupId; sel.style.display = 'none'; }
        }
    }

    function escapeHtml(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

    function getCommitIcon(msg) {
        if (!msg) return 'code';
        const m = msg.toLowerCase();
        if (m.startsWith('fix')) return 'fix';
        if (m.startsWith('feat')) return 'feat';
        if (m.startsWith('chore') || m.startsWith('docs')) return 'chore';
        return 'feat';
    }

    async function loadAll() {
        if (isTeamMember && !currentUserId) {
            const me = await fetch('/api/auth/me', opts).then(r => r.json()).catch(() => null);
            if (me) currentUserId = me.id;
        }
        await Promise.all([loadMemberCards(), loadChart(), loadCommitHistory()]);
    }

    async function loadMemberCards() {
        const el = document.getElementById('memberCards');
        if (isTeamMember && currentUserId) {
            const stats = await fetch('/api/reports/personal-stats', opts).then(r => r.json()).catch(() => ({}));
            const commits = await fetch('/api/reports/commits?userId=' + currentUserId + '&limit=500', opts).then(r => r.json()).catch(() => []);
            const me = await fetch('/api/auth/me', opts).then(r => r.json()).catch(() => ({}));
            const name = me.userName || me.email || 'Bạn';
            const initial = (name.charAt(0) || 'U').toUpperCase();
            el.innerHTML = `
                <div class="member-card">
                    <div class="avatar">${escapeHtml(initial)}</div>
                    <div class="name">${escapeHtml(name)}</div>
                    <div class="commits">${stats.totalCommits ?? commits.length} commits</div>
                </div>`;
            return;
        }
        if (!currentGroupId && (isLecturer || isAdmin)) {
            el.innerHTML = '<p class="text-muted">Chọn nhóm để xem thống kê.</p>';
            return;
        }
        if (!currentGroupId && isTeamLeader) {
            el.innerHTML = '<p class="text-muted">Bạn chưa thuộc nhóm nào.</p>';
            return;
        }
        const res = await fetch('/api/reports/commit-stats?groupId=' + currentGroupId, opts);
        const data = await res.json();
        if (!data.byUser || !data.byUser.length) {
            el.innerHTML = '<p class="text-muted">Chưa có commit nào trong nhóm.</p>';
            return;
        }
        el.innerHTML = data.byUser.map(u => {
            const initial = (u.userName || u.email || '?').charAt(0).toUpperCase();
            return `<div class="member-card">
                <div class="avatar">${escapeHtml(initial)}</div>
                <div class="name">${escapeHtml(u.userName || u.email)}</div>
                <div class="commits">${u.commitCount} commits</div>
            </div>`;
        }).join('');
    }

    async function loadChart() {
        const el = document.getElementById('chartContainer');
        const url = isTeamMember && currentUserId
            ? '/api/reports/commits-by-week?userId=' + currentUserId + '&weeks=6'
            : currentGroupId
                ? '/api/reports/commits-by-week?groupId=' + currentGroupId + '&weeks=6'
                : null;
        if (!url) {
            el.innerHTML = '<p class="text-muted">Chọn nhóm hoặc xem dữ liệu của bạn.</p>';
            return;
        }
        const res = await fetch(url, opts);
        const data = await res.json();
        if (!data.labels || !data.labels.length) {
            el.innerHTML = '<p class="text-muted">Chưa có dữ liệu commit theo tuần.</p>';
            return;
        }
        const maxVal = Math.max(1, ...(data.datasets || []).flatMap(d => d.data || []));
        const colors = ['#3b82f6', '#10b981', '#f59e0b', '#8b5cf6', '#ec4899'];
        let html = '<div class="chart-bars">';
        (data.labels || []).forEach((label, i) => {
            html += '<div class="chart-bar-wrap"><div style="display: flex; flex-direction: row; align-items: flex-end; justify-content: center; gap: 3px; min-height: 100px;">';
            (data.datasets || []).forEach((ds, j) => {
                const v = (ds.data && ds.data[i]) || 0;
                const h = maxVal > 0 ? (v / maxVal) * 100 : 0;
                html += `<div class="chart-bar" style="height:${h}px; width: 20px; background:${colors[j % colors.length]};" title="${escapeHtml(ds.userName)}: ${v} commit(s)"></div>`;
            });
            html += '</div><span style="font-size:0.7rem;color:var(--text-muted);margin-top:4px;">' + escapeHtml(label) + '</span></div>';
        });
        html += '</div>';
        if (data.datasets && data.datasets.length) {
            html += '<div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:0.75rem;font-size:0.8125rem;">';
            data.datasets.forEach((ds, j) => {
                html += `<span style="color:${colors[j % colors.length]}"><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:currentColor;vertical-align:middle;"></span> ${escapeHtml(ds.userName)}</span>`;
            });
            html += '</div>';
        }
        el.innerHTML = html;
    }

    async function loadCommitHistory() {
        const el = document.getElementById('commitHistoryList');
        const url = isTeamMember && currentUserId
            ? '/api/reports/commits?userId=' + currentUserId + '&limit=200'
            : currentGroupId
                ? '/api/reports/commits?groupId=' + currentGroupId + '&limit=200'
                : null;
        if (!url) {
            el.innerHTML = '<p class="text-muted">Chọn nhóm để xem lịch sử commit.</p>';
            return;
        }
        const res = await fetch(url, opts);
        allCommits = await res.json();
        renderCommitList(allCommits);
    }

    function renderCommitList(commits) {
        const el = document.getElementById('commitHistoryList');
        const q = (document.getElementById('searchCommit') || {}).value || '';
        const ql = q.toLowerCase().trim();
        const list = ql ? commits.filter(c => (c.message || '').toLowerCase().includes(ql)) : commits;
        if (!list.length) {
            el.innerHTML = '<p class="text-muted">Không có commit nào.</p>';
            return;
        }
        el.innerHTML = list.map(c => {
            const icon = getCommitIcon(c.message);
            const date = c.committedAt ? new Date(c.committedAt).toLocaleString('vi-VN') : '';
            return `<div class="commit-item">
                <div class="commit-icon ${icon}">${icon === 'feat' ? '+' : icon === 'fix' ? '!' : '·'}</div>
                <div class="body">
                    <div class="message">${escapeHtml(c.message || '(no message)')}</div>
                    <div class="meta">${escapeHtml(c.authorName || '?')} | ${escapeHtml(date)}</div>
                </div>
                <div class="sha" title="${escapeHtml(c.sha || '')}">${escapeHtml((c.sha || '').substring(0, 7))}</div>
            </div>`;
        }).join('');
    }

    document.getElementById('searchCommit').oninput = () => renderCommitList(allCommits);

    (async function init() {
        await loadGroups();
        if (isTeamMember) {
            const me = await fetch('/api/auth/me', opts).then(r => r.json()).catch(() => null);
            if (me) currentUserId = me.id;
        }
        await loadAll();
    })();
})();
</script>
