@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Quản trị viên";
}

<div class="page-header animate__animated animate__fadeIn">
    <h1 class="page-title">Tổng quan hệ thống</h1>
    <p class="text-muted">Chào mừng trở lại, @User.Identity?.Name</p>
</div>

<div class="stats-grid">
    <div class="stat-card animate__animated animate__zoomIn" style="animation-delay: 0.1s">
        <div class="stat-icon stat-icon-blue"><i class="fas fa-users"></i></div>
        <div id="statGroups" class="stat-value">0</div>
        <div class="stat-label">Tổng số nhóm</div>
    </div>
    <div class="stat-card animate__animated animate__zoomIn" style="animation-delay: 0.2s">
        <div class="stat-icon stat-icon-purple"><i class="fas fa-user-tie"></i></div>
        <div id="statLecturers" class="stat-value">0</div>
        <div class="stat-label">Giảng viên</div>
    </div>
    <div class="stat-card animate__animated animate__zoomIn" style="animation-delay: 0.3s">
        <div class="stat-icon stat-icon-green"><i class="fas fa-check-circle"></i></div>
        <div id="statTasks" class="stat-value">0</div>
        <div class="stat-label">Tổng tasks</div>
    </div>
    <div class="stat-card animate__animated animate__zoomIn" style="animation-delay: 0.4s">
        <div class="stat-icon stat-icon-amber"><i class="fas fa-code-branch"></i></div>
        <div id="statCommits" class="stat-value">0</div>
        <div class="stat-label">Tổng commits</div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="content-card animate__animated animate__fadeInUp" style="animation-delay: 0.2s">
        <div class="card-header">
            <h2 class="card-title">Danh sách nhóm</h2>
            <a href="/Dashboard/Groups" class="link-primary">Xem tất cả</a>
        </div>
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Mã nhóm</th>
                        <th>Tên nhóm</th>
                        <th>Jira Key</th>
                        <th>GitHub Repo</th>
                    </tr>
                </thead>
                <tbody id="recentGroupsBody">
                    <tr><td colspan="4" class="text-center" style="padding: 2rem;">Đang tải...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="content-card animate__animated animate__fadeInUp" style="animation-delay: 0.3s">
        <div class="card-header">
            <h2 class="card-title">Thao tác nhanh</h2>
        </div>
        <div class="flex flex-column gap-4">
            <a href="/Dashboard/Groups" class="quick-link"><i class="fas fa-users"></i> Quản lý nhóm</a>
            <a href="/Dashboard/Lecturers" class="quick-link"><i class="fas fa-user-tie"></i> Quản lý giảng viên</a>
            <a href="/Dashboard/Sync" class="quick-link"><i class="fas fa-sync"></i> Đồng bộ Jira / GitHub</a>
            <a href="/Dashboard/Settings" class="quick-link"><i class="fas fa-cog"></i> Cài đặt</a>
        </div>
    </div>
</div>

<script>
(function() {
    const opts = { credentials: 'include' };
    async function load() {
        try {
            const [gRes, lRes, tRes] = await Promise.all([
                fetch('/api/groups', opts),
                fetch('/api/admin/lecturers', opts),
                fetch('/api/tasks', opts)
            ]);
            const groups = await gRes.json();
            const lecturers = await lRes.json();
            const tasks = await tRes.json();
            document.getElementById('statGroups').textContent = groups.length;
            document.getElementById('statLecturers').textContent = lecturers.length;
            document.getElementById('statTasks').textContent = Array.isArray(tasks) ? tasks.length : 0;
            var totalCommits = 0;
            for (var i = 0; i < Math.min(5, groups.length); i++) {
                try {
                    var r = await fetch('/api/reports/commit-stats?groupId=' + groups[i].id, opts);
                    if (r.ok) { var dt = await r.json(); if (dt.byUser) totalCommits += dt.byUser.reduce(function(s, x) { return s + (x.count || 0); }, 0); }
                } catch (e) {}
            }
            document.getElementById('statCommits').textContent = totalCommits;
            var tbody = document.getElementById('recentGroupsBody');
            var list = groups.slice(0, 8);
            if (list.length === 0) tbody.innerHTML = '<tr><td colspan="4" class="text-center" style="padding: 2rem; color: var(--text-muted);">Chưa có nhóm.</td></tr>';
            else tbody.innerHTML = list.map(function(g) {
                return '<tr><td>' + (g.code || '') + '</td><td>' + (g.name || '') + '</td><td><span class="text-muted">' + (g.jiraProjectKey || '—') + '</span></td><td><span class="text-muted">' + (g.githubRepo || '—') + '</span></td></tr>';
            }).join('');
        } catch (e) {
            document.getElementById('recentGroupsBody').innerHTML = '<tr><td colspan="4" class="text-center" style="padding: 2rem; color: #f87171;">Lỗi tải dữ liệu.</td></tr>';
        }
    }
    if (document.readyState === 'loading') window.addEventListener('DOMContentLoaded', load); else load();
})();
</script>
