@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Thành viên";
}

<div class="page-header animate__animated animate__fadeIn">
    <h1 class="page-title">Công việc của tôi</h1>
    <p class="text-muted">Xem và cập nhật trạng thái công việc được giao.</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon bg-blue-500/10 text-blue-500"><i class="fas fa-clipboard-list"></i></div>
        <div class="stat-value">5</div>
        <div class="stat-label">Tasks được giao</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon bg-yellow-500/10 text-yellow-500"><i class="fas fa-spinner"></i></div>
        <div class="stat-value">2</div>
        <div class="stat-label">Đang thực hiện</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon bg-green-500/10 text-green-500"><i class="fas fa-check-double"></i></div>
        <div class="stat-value">3</div>
        <div class="stat-label">Đã hoàn thành</div>
    </div>
</div>

<div class="content-card animate__animated animate__fadeInUp">
    <div class="card-header">
        <h2 class="card-title">Tasks assigned to me</h2>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Jira Key</th>
                <th>Công việc</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>FK-TM01</td>
                <td>Implement Login Interface</td>
                <td><span class="status-badge status-progress">In Progress</span></td>
                <td>
                    <select class="form-control py-1 px-2 text-xs" style="width: auto;">
                        <option>InProgress</option>
                        <option>Done</option>
                    </select>
                </td>
            </tr>
            <tr>
                <td>FK-TM02</td>
                <td>Unit test for Auth</td>
                <td><span class="status-badge status-todo">Todo</span></td>
                <td>
                     <select class="form-control py-1 px-2 text-xs" style="width: auto;">
                        <option selected>Todo</option>
                        <option>InProgress</option>
                        <option>Done</option>
                    </select>
                </td>
            </tr>
        </tbody>
    </table>
</div>
