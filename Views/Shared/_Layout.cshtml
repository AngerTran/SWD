<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SWP Tracker</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

<header>
    <nav class="navbar navbar-expand-lg fixed-top border-0">
        <div class="container">
            <a class="navbar-brand text-white d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <span class="p-2 bg-primary bg-opacity-10 rounded-3 me-2" style="border: 1px solid rgba(59,130,246,0.3)">
                    <i class="bi bi-lightning-charge-fill text-primary"></i>
                </span>
                SWP Tracker
            </a>

            <button class="navbar-toggler border-0 text-white" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <i class="bi bi-list fs-2"></i>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white opacity-75" href="#features">Tính năng</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white opacity-75" href="#">Tài liệu</a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item ms-lg-3">
                            <a class="btn btn-primary-glow px-4 rounded-pill"
                               asp-controller="Dashboard"
                               asp-action="Index">
                               Dashboard
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-lg-3">
                            <a class="btn btn-outline-light px-4 rounded-pill border-opacity-25"
                               asp-controller="Account"
                               asp-action="Login">
                               Đăng nhập
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<main>
    @RenderBody()
</main>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
